# Copy to .env (same folder) and fill in. The server reads this at startup.

# ── Postgres ────────────────────────────────────────────────────────────────
# Either a single connection string…
DATABASE_URL=postgres://user:password@localhost:5432/coupleworld
# …or the standard PG* variables (used only if DATABASE_URL is not set):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=coupleworld
# PGPASSWORD=secret
# PGDATABASE=coupleworld
#
# If neither is configured, the server runs in legacy open mode (no accounts).

# ── Auth ────────────────────────────────────────────────────────────────────
# Long random string — REQUIRED in production; tokens are signed with it.
JWT_SECRET=change-me-to-a-long-random-string

# First-boot admin account (created only when the users table is empty).
# The admin must change this password on first sign-in.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# ── Server ──────────────────────────────────────────────────────────────────
# PORT=3000
