# Copy to .env (same folder) and fill in. The server reads this at startup.

# ── Postgres ────────────────────────────────────────────────────────────────
# Either a single connection string…
DATABASE_URL=postgres://user:password@localhost:5432/coupleworld
# …or the standard PG* variables (used only if DATABASE_URL is not set):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=coupleworld
# PGPASSWORD=secret
# PGDATABASE=coupleworld
#
# If neither is configured, the server runs in legacy open mode (no accounts).

# ── Auth ────────────────────────────────────────────────────────────────────
# Long random string — REQUIRED in production; tokens are signed with it.
JWT_SECRET=change-me-to-a-long-random-string

# First-boot admin account (created only when the users table is empty).
# The admin must change this password on first sign-in.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# ── Server ──────────────────────────────────────────────────────────────────
# PORT=3000
# How many people fit in the world (default 2 — it's a couple's world 💕)
# MAX_PLAYERS=2

# ── Split deployment (only if the frontend is hosted separately) ────────────
# If this backend serves the frontend itself (default, incl. one Render Web
# Service), leave this unset. If the frontend lives on another origin (e.g.
# a Render Static Site), list it here (comma-separated for several) AND set
# window.API_BASE_URL in frontend/env.js to this backend's URL.
# FRONTEND_ORIGIN=https://your-frontend.onrender.com
